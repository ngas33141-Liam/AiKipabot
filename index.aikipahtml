<!DOCTYPE html>
<html>
<head>
    <title>AiKipa</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body{
            margin:0;
            background:#0f172a;
            color:white;
            font-family:Arial;

            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
        }

        .container{
            text-align:center;
        }

        button{
            padding:15px 25px;
            border:none;
            border-radius:10px;
            background:#06b6d4;
            color:white;
            font-size:18px;
            cursor:pointer;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>AiKipa</h1>
        <p>Welcome to AiKipa Mini App</p>

        <button onclick="sayHello()">
            Start
        </button>
    </div>

    <script>
        console.log("AiKipa");

        function sayHello() {
            alert("Hello from AiKipa!");
        }
    </script>

</body>
</html>
